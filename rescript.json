{
  "name": "rescript-string-power",
  "version": "0.1.0",
  "sources": [
    {
      "dir": "src",
      "subdirs": true
    }
  ],
  "package-specs": [
    {
      "module": "esmodule",
      "in-source": true
    }
  ],
  "suffix": ".res.mjs",
  "bs-dependencies": [
    "@rescript/react",
    "@rescript/core"
  ],
  "warnings": {
    "error": "+101"
  },
  "jsx": {
    "version": 4,
    "mode": "automatic"
  }
}
